# =============================================================================
# AIPresence Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Settings marked [reload-safe] can be changed at runtime via
# POST /admin/reload-config without restarting the backend.
#
# Settings marked [restart-only] require a full backend restart to take effect.
# =============================================================================

# --- Home Assistant connection (optional — omit both for standalone mode) ---
# [reload-safe] Changing these recreates the data source and re-injects it
# into all sensors/trackers.
HA_URL=https://your-home-assistant-instance/api
HA_TOKEN=your_long_lived_access_token

# --- Persistence [restart-only] ---
DATA_PATH=data
DB_FILENAME=aipresence.db

# --- ML training [reload-safe] ---
SAMPLE_RATE=2.0
MINIMUM_TRAINING_SAMPLES=200

# --- Logging [reload-safe] ---
# Accepted values: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
